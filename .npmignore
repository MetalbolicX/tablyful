# The "files" field in package.json is the primary control for what gets
# published. Only "dist/" is shipped to npm consumers.
#
# This file acts as a secondary safety net inside published directories.

# Source maps (if ever generated)
*.map

# TypeScript source files (should not appear in dist/, but just in case)
*.ts
*.mts

# Test artifacts
*.test.*
__snapshots__/
