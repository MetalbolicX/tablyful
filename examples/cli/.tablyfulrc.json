{
  "defaultFormat": "json",
  "json": {
    "pretty": true,
    "indentSize": 2,
    "asArray": false
  },
  "csv": {
    "delimiter": ",",
    "includeHeaders": true
  },
  "markdown": {
    "align": "left",
    "padding": true,
    "githubFlavor": true
  },
  "sql": {
    "tableName": "people",
    "identifierQuote": "\"",
    "includeCreateTable": true
  },
  "yaml": {
    "indent": 2,
    "quoteStrings": false,
    "lineBreak": "\n"
  }
}
